# Alpaca Markets Paper Trading
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server (Railway sets PORT automatically — do not override in Railway dashboard)
PORT=3001
NODE_ENV=production

# Optional: path to SQLite DB file (defaults to server/data/daylens.db)
# On Railway, set this to /data/daylens.db if you attach a persistent volume
# DB_PATH=/data/daylens.db
